{
  "name": "buildweaver",
  "private": true,
  "version": "0.1.0",
  "description": "BuildWeaver monorepo",
  "packageManager": "pnpm@8.10.0",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "concurrently \"pnpm --filter @buildweaver/editor dev\" \"pnpm --filter @buildweaver/api start:dev\"",
    "prepare": "husky install",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^6.11.0",
    "@typescript-eslint/parser": "^6.11.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.1.0",
    "prettier": "^3.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3"
  }
}
