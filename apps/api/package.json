{
  "name": "@buildweaver/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/apps/api/src/main.js",
    "start:dev": "cross-env NODE_OPTIONS=--loader=ts-node/esm ts-node-dev --respawn --transpile-only --require tsconfig-paths/register src/main.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "typecheck": "tsc --project tsconfig.build.json --noEmit",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand"
  },
  "dependencies": {
    "@buildweaver/db": "workspace:*",
    "@buildweaver/libs": "workspace:*",
    "@buildweaver/llm": "workspace:*",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.2",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.4.2",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cross-env": "^10.1.0",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.44.7",
    "helmet": "^7.1.0",
    "nestjs-pino": "^3.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.3",
    "pino": "^8.16.0",
    "pino-http": "^8.6.1",
    "pino-pretty": "^10.2.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "ssh2": "^1.16.0",
    "ts-node-dev": "^2.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.0.1",
    "@nestjs/testing": "^10.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.4",
    "@types/passport-jwt": "^3.0.9",
    "@types/pg": "^8.6.6",
    "@types/ssh2": "^1.15.5",
    "@types/supertest": "^2.0.16",
    "jest": "^29.7.0",
    "pg-mem": "^3.0.5",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
